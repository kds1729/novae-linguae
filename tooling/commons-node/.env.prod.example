# Production .env for the commons node (Arca) — copy to .env, fill the secrets, then:
#   docker compose -f docker-compose.prod.yml up -d --build
# Unlike .env.example (the dev, host-Django profile), this targets the containerized prod stack: the
# service hostnames are docker names (db / redis / embeddings), which docker-compose.prod.yml also pins.

# --- Django ---
COMMONS_SECRET_KEY=CHANGE_ME__64_hex_chars__openssl_rand_-hex_32
COMMONS_DEBUG=0
COMMONS_ALLOWED_HOSTS=nl.1105software.com,127.0.0.1,localhost

# --- Postgres (pgvector). POSTGRES_* in compose are derived from these. ---
COMMONS_PG_NAME=commons
COMMONS_PG_USER=commons
COMMONS_PG_PASSWORD=CHANGE_ME__strong_db_password
COMMONS_PG_HOST=db
COMMONS_PG_PORT=5432

# --- Redis (cache + Celery broker + egress counter) ---
COMMONS_REDIS_URL=redis://redis:6379/0
COMMONS_CELERY_BROKER=redis://redis:6379/0

# --- Neural embeddings (TEI bge-small-en-v1.5; dim must match the served model) ---
COMMONS_EMBEDDER=bge-small-en-v1.5
COMMONS_EMBEDDING_DIM=384
COMMONS_EMBEDDINGS_URL=http://embeddings:80

# --- Egress-budget governor (the only variable cost). IONOS gives the first 2 TB/month free; a
#     1.5 TB/month hard cap stays comfortably under it. 0 = meter only, no throttle. ---
COMMONS_EGRESS_BUDGET_BYTES=1500000000000

# --- Replication worker (optional). Comma-separated peer base URLs to mirror from; empty = pure origin.
COMMONS_PEERS=
COMMONS_REPLICATE_INTERVAL=300
COMMONS_EMBED_INTERVAL=120
