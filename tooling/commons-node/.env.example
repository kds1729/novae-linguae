# Copy to .env and `set -a; source .env; set +a` before `manage.py runserver` to run against the
# production-shaped stack (docker-compose.yml). Leave ALL of these unset and the node falls back to
# the zero-dependency path: SQLite + the stdlib lexical embedder, no containers required.

# --- Postgres (pgvector) — activates the Postgres backend + pgvector ANN search ---
COMMONS_PG_NAME=commons
COMMONS_PG_USER=commons
COMMONS_PG_PASSWORD=commons
COMMONS_PG_HOST=127.0.0.1
COMMONS_PG_PORT=5432

# --- Redis (hot cache element) ---
COMMONS_REDIS_URL=redis://127.0.0.1:6379/0

# --- Neural embeddings (TEI model server) ---
# COMMONS_EMBEDDER is the model id this node advertises (in /v0/info and every search result) and
# pins for comparability. Anything other than a lexical-hashing id selects the neural embedder, which
# calls COMMONS_EMBEDDINGS_URL. DIM must match the served model (bge-small-en-v1.5 = 384).
COMMONS_EMBEDDER=bge-small-en-v1.5
COMMONS_EMBEDDING_DIM=384
COMMONS_EMBEDDINGS_URL=http://127.0.0.1:8080
