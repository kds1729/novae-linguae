{
  "openapi": "3.0.0",
  "info": {
    "title": "Search Service",
    "version": "1.0.0",
    "description": "The GW10 reference description: $ref-factored components, query and header parameters, apiKey-in-header auth, an optional parameter (omitted with a note), and a multipart operation (refused honestly)."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8878"
    }
  ],
  "components": {
    "securitySchemes": {
      "api_key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key"
      }
    },
    "parameters": {
      "Query": {
        "name": "q",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer"
        }
      },
      "ClientId": {
        "name": "X-Client-Id",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "OK": {
        "description": "OK."
      },
      "BadRequest": {
        "description": "Missing or malformed parameter."
      }
    }
  },
  "security": [
    {
      "api_key": []
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchItems",
        "summary": "Search stored items by term, capped at limit results.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Query"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Offset"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/OK"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/version": {
      "get": {
        "operationId": "getVersion",
        "summary": "Service version; requires a client identifier header.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientId"
          }
        ],
        "responses": {
          "200": {
            "description": "OK — the fixed service version.",
            "content": {
              "application/json": {
                "example": { "version": "1.0.0" }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/upload": {
      "post": {
        "operationId": "uploadArchive",
        "summary": "Multipart upload — deliberately outside the description subset (a refusal case).",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Uploaded."
          }
        }
      }
    }
  }
}
