{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novae-linguae.org/spec/v0.2/function-record.schema.json",
  "title": "Nova Lingua Function Record (v0.2)",
  "description": "v0.2 of the function-record schema. The change from v0.1 is structural — four fields that v0.1 stringified are now structured ASTs: signature.type uses the type-expression form; signature.refinements[].expr and properties[].expr use the predicate-expression form; examples[].args[] and examples[].result use the value-expression form. v0.1 records remain valid against their pinned v0.1 schema; this schema accepts v0.2 records only (schema_version pinned to 0.2.0). The sub-schemas are inlined under $defs (with prefixes te_, pe_, ve_ to avoid name collisions) for self-containment: a v0.2 validator does not need cross-file schema resolution. The inlined sub-schemas are content-equivalent to the standalone files (type-expression.schema.json, predicate-expression.schema.json, value-expression.schema.json) at v0.1; any divergence is a bug. The reference validator now supports cross-file $ref resolution (used by message.schema.json for payload validation), so the inlining here is a deliberate self-containment choice rather than a tooling limitation; a future major bump may switch to cross-file $refs and remove the duplication.",
  "type": "object",
  "required": [
    "schema_version",
    "hash",
    "signature",
    "examples",
    "body_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "hash": { "$ref": "#/$defs/content_address" },
    "name_hints": {
      "type": "array",
      "items": { "$ref": "#/$defs/name_hint" },
      "uniqueItems": true,
      "default": []
    },
    "signature": { "$ref": "#/$defs/signature" },
    "examples": {
      "type": "array",
      "items": { "$ref": "#/$defs/example" },
      "minItems": 1
    },
    "properties": {
      "type": "array",
      "items": { "$ref": "#/$defs/property" },
      "default": []
    },
    "intent_tags": {
      "type": "array",
      "items": { "$ref": "#/$defs/intent_tag" },
      "uniqueItems": true,
      "default": []
    },
    "derived_from": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/content_address" },
          "minItems": 1,
          "uniqueItems": true
        }
      ],
      "default": null
    },
    "supersedes": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/content_address" }
      ],
      "default": null
    },
    "body_hash": { "$ref": "#/$defs/content_address" }
  },
  "$defs": {
    "content_address": {
      "type": "string",
      "pattern": "^(fn|expr|type|proof|msg)_[0-9a-f]{64}$"
    },
    "name_hint": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "minLength": 1,
      "maxLength": 64
    },
    "intent_tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(/[a-z][a-z0-9-]*)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "effect": {
      "type": "string",
      "enum": [
        "fs.read",
        "fs.write",
        "net.read",
        "net.write",
        "alloc",
        "time",
        "random",
        "io.console",
        "process.spawn",
        "panic"
      ]
    },
    "capability": {
      "type": "string",
      "pattern": "^cap:[a-z][a-z0-9_-]*(/[a-z][a-z0-9_-]*)*$",
      "minLength": 5,
      "maxLength": 128
    },
    "signature": {
      "type": "object",
      "required": ["type", "effects", "capabilities", "terminates"],
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/te_type" },
        "refinements": {
          "type": "array",
          "items": { "$ref": "#/$defs/refinement" },
          "default": []
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" },
          "uniqueItems": true
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability" },
          "uniqueItems": true
        },
        "complexity": {
          "type": "string",
          "pattern": "^O\\([^)]+\\)$"
        },
        "cost": { "$ref": "#/$defs/cost" },
        "terminates": {
          "type": "string",
          "enum": ["always", "conditional", "never", "unknown"]
        }
      }
    },
    "cost": {
      "type": "object",
      "description": "Structured cost metadata enabling PRECISE complexity composition through pipelines (v0.3). `time` is the function's running-time class in terms of its input `measure`; `output_size` is how its result size relates to its input size, so a downstream stage's cost can be re-expressed in the pipeline's input size. The flat `complexity` string above is the coarse, composition-unaware bound; `cost` is the richer, composable form.",
      "required": ["time", "output_size"],
      "additionalProperties": false,
      "properties": {
        "time": {
          "type": "string",
          "pattern": "^O\\([^)]+\\)$",
          "description": "Running-time class as a function of the input measure: O(1), O(log n), O(n), O(n log n), O(n^2), O(n^2 log n), O(n^3)."
        },
        "measure": {
          "type": "string",
          "enum": ["size", "value"],
          "default": "size",
          "description": "What `n` counts in `time`: the input's structural SIZE (e.g. list length) or its numeric VALUE (e.g. a counter a loop runs to). Only size-measured costs substitute soundly through a pipeline; a value-measured stage makes the composite fall back to the coarse bound."
        },
        "output_size": {
          "type": "string",
          "enum": ["constant", "preserving", "bounded", "quadratic", "cubic", "unknown"],
          "description": "Output size vs input size: constant (O(1), e.g. length/head), preserving (Theta(n), e.g. reverse/map), bounded (<= n, e.g. filter), quadratic (Theta(n^2), an expanding stage), cubic (Theta(n^3)), or unknown."
        }
      }
    },
    "refinement": {
      "type": "object",
      "description": "A contract on the function. `expr` is a predicate over the function's parameters (by name); a `post` predicate additionally refers to the function's output through the reserved variable `result`. Conventionally `pre` is a precondition on the inputs (assumed when discharging the posts), `post` a postcondition on `result` given the pres, and `inv` an invariant. The reference validator's `check-refinement` proves each `post` as `forall params. (and pre) => post[result := body(params)]` (folding in the non-negativity of `nat`-typed params); `inv` is reserved (not yet checked).",
      "required": ["kind", "expr"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["pre", "post", "inv"]
        },
        "expr": { "$ref": "#/$defs/pe_predicate" }
      }
    },
    "property": {
      "type": "object",
      "required": ["name", "expr"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "expr": { "$ref": "#/$defs/pe_predicate" }
      }
    },
    "example": {
      "type": "object",
      "required": ["args", "result"],
      "additionalProperties": false,
      "properties": {
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/ve_value" }
        },
        "result": { "$ref": "#/$defs/ve_value" },
        "trace": {
          "type": "string",
          "pattern": "^trc_[0-9a-f]{64}$",
          "description": "Optional content-address of a recorded effect trace (trace.schema.json) for an EFFECTFUL example: the observations of one real run of this example. With it, `run` replays the example deterministically — no effect grants, no secrets, no live service — so a commons consumer can check an effectful record's examples offline (the record-level counterpart of an `observed` claim; same honest scope — the trace itself is the publisher's testimony). Pure examples never need one."
        }
      }
    },

    "te_type": {
      "oneOf": [
        { "$ref": "#/$defs/te_var" },
        { "$ref": "#/$defs/te_ref" },
        { "$ref": "#/$defs/te_builtin" },
        { "$ref": "#/$defs/te_forall" },
        { "$ref": "#/$defs/te_fn" },
        { "$ref": "#/$defs/te_apply" },
        { "$ref": "#/$defs/te_tuple" },
        { "$ref": "#/$defs/te_record" },
        { "$ref": "#/$defs/te_sum" }
      ]
    },
    "te_var": {
      "type": "object",
      "required": ["kind", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "var" },
        "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_']*$", "minLength": 1, "maxLength": 64 }
      }
    },
    "te_ref": {
      "type": "object",
      "required": ["kind", "target"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "ref" },
        "target": { "type": "string", "pattern": "^type_[0-9a-f]{64}$" }
      }
    },
    "te_builtin": {
      "type": "object",
      "required": ["kind", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "builtin" },
        "name": {
          "type": "string",
          "enum": [
            "bool", "int", "nat", "float", "string", "bytes", "unit", "never",
            "List", "Maybe", "Result", "Map", "Set", "Json"
          ]
        }
      }
    },
    "te_forall": {
      "type": "object",
      "required": ["kind", "vars", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "forall" },
        "vars": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_']*$", "minLength": 1, "maxLength": 64 }
        },
        "body": { "$ref": "#/$defs/te_type" }
      }
    },
    "te_fn": {
      "type": "object",
      "required": ["kind", "params", "result"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "fn" },
        "params": { "type": "array", "items": { "$ref": "#/$defs/te_type" } },
        "result": { "$ref": "#/$defs/te_type" }
      }
    },
    "te_apply": {
      "type": "object",
      "required": ["kind", "ctor", "args"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "apply" },
        "ctor": { "$ref": "#/$defs/te_type" },
        "args": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/te_type" }
        }
      }
    },
    "te_tuple": {
      "type": "object",
      "required": ["kind", "elems"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "tuple" },
        "elems": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/te_type" }
        }
      }
    },
    "te_record": {
      "type": "object",
      "required": ["kind", "fields"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "record" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_]*$", "minLength": 1, "maxLength": 64 },
              "type": { "$ref": "#/$defs/te_type" }
            }
          }
        }
      }
    },
    "te_sum": {
      "type": "object",
      "required": ["kind", "variants"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "sum" },
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["tag"],
            "additionalProperties": false,
            "properties": {
              "tag": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9_]*$", "minLength": 1, "maxLength": 64 },
              "type": { "$ref": "#/$defs/te_type" }
            }
          }
        }
      }
    },

    "pe_predicate": {
      "oneOf": [
        { "$ref": "#/$defs/pe_var" },
        { "$ref": "#/$defs/pe_lit" },
        { "$ref": "#/$defs/pe_app" },
        { "$ref": "#/$defs/pe_forall" },
        { "$ref": "#/$defs/pe_exists" }
      ]
    },
    "pe_var": {
      "type": "object",
      "required": ["kind", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "var" },
        "name": { "type": "string", "pattern": "^[a-z_][a-zA-Z0-9_']*$", "minLength": 1, "maxLength": 64 }
      }
    },
    "pe_lit": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "lit" },
        "value": {}
      }
    },
    "pe_app": {
      "type": "object",
      "required": ["kind", "op", "args"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "app" },
        "op": { "type": "string", "minLength": 1, "maxLength": 256 },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/pe_predicate" }
        }
      }
    },
    "pe_forall": {
      "type": "object",
      "required": ["kind", "vars", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "forall" },
        "vars": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z_][a-zA-Z0-9_']*$", "minLength": 1, "maxLength": 64 }
        },
        "body": { "$ref": "#/$defs/pe_predicate" }
      }
    },
    "pe_exists": {
      "type": "object",
      "required": ["kind", "vars", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "exists" },
        "vars": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z_][a-zA-Z0-9_']*$", "minLength": 1, "maxLength": 64 }
        },
        "body": { "$ref": "#/$defs/pe_predicate" }
      }
    },

    "ve_value": {
      "oneOf": [
        { "$ref": "#/$defs/ve_bool" },
        { "$ref": "#/$defs/ve_int" },
        { "$ref": "#/$defs/ve_nat" },
        { "$ref": "#/$defs/ve_float" },
        { "$ref": "#/$defs/ve_string" },
        { "$ref": "#/$defs/ve_bytes" },
        { "$ref": "#/$defs/ve_unit" },
        { "$ref": "#/$defs/ve_list" },
        { "$ref": "#/$defs/ve_tuple" },
        { "$ref": "#/$defs/ve_record" },
        { "$ref": "#/$defs/ve_variant" },
        { "$ref": "#/$defs/ve_fn_ref" },
        { "$ref": "#/$defs/ve_map" }
      ]
    },
    "ve_bool": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "bool" },
        "value": { "type": "boolean" }
      }
    },
    "ve_int": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "int" },
        "value": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string", "pattern": "^-?(0|[1-9][0-9]*)$" }
          ]
        }
      }
    },
    "ve_nat": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "nat" },
        "value": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" }
          ]
        }
      }
    },
    "ve_float": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "float" },
        "value": { "type": "number" }
      }
    },
    "ve_string": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "string" },
        "value": { "type": "string" }
      }
    },
    "ve_bytes": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "bytes" },
        "value": { "type": "string", "pattern": "^[A-Za-z0-9+/]*={0,2}$" }
      }
    },
    "ve_unit": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": { "kind": { "const": "unit" } }
    },
    "ve_list": {
      "type": "object",
      "required": ["kind", "elems"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "list" },
        "elems": { "type": "array", "items": { "$ref": "#/$defs/ve_value" } }
      }
    },
    "ve_tuple": {
      "type": "object",
      "required": ["kind", "elems"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "tuple" },
        "elems": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/ve_value" } }
      }
    },
    "ve_record": {
      "type": "object",
      "required": ["kind", "fields"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "record" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_]*$", "minLength": 1, "maxLength": 64 },
              "value": { "$ref": "#/$defs/ve_value" }
            }
          }
        }
      }
    },
    "ve_variant": {
      "type": "object",
      "required": ["kind", "tag"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "variant" },
        "tag": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9_]*$", "minLength": 1, "maxLength": 64 },
        "payload": { "$ref": "#/$defs/ve_value" }
      }
    },
    "ve_fn_ref": {
      "type": "object",
      "required": ["kind", "target"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "fn_ref" },
        "target": { "type": "string", "pattern": "^fn_[0-9a-f]{64}$" }
      }
    },
    "ve_map": {
      "type": "object",
      "required": ["kind", "entries"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "map" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string" },
              "value": { "$ref": "#/$defs/ve_value" }
            }
          }
        }
      }
    }
  }
}
