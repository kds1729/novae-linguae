                  {
                    "kind": "app",
                    "op": "map",
                    "args": [{ "kind": "var", "name": "f" }, { "kind": "var", "name": "xs" }]
                  }
                ]
              },
              { "kind": "app", "op": "length", "args": [{ "kind": "var", "name": "xs" }] }
            ]
          }
        }
