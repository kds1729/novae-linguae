                "kind": "variant",
                "tag": "Some",
                "payload": { "kind": "bind", "name": "x" }
              },
              "body": { "kind": "var", "name": "x" }
            },
            {
              "pattern": { "kind": "variant", "tag": "None" },
              "body": { "kind": "lit", "value": { "kind": "nat", "value": 0 } }
